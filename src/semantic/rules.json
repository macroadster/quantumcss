{
  "mail": {
    "components": {
      "sidebar": {
        "selector": ".email-sidebar",
        "targetTag": "nav",
        "stripClasses": true,
        "removeAttributes": ["style"],
        "rules": [
          { "selector": ".compose-btn", "tag": "button", "addClass": "compose", "keepAttributes": ["onclick"] },
          { "selector": ".nav-item", "tag": "a", "stripClasses": true, "removeAttributes": ["style"] },
          { "selector": ".nav-section-title", "tag": "h6", "stripClasses": true, "removeAttributes": ["style"] },
          { "selector": ".user-profile-section", "tag": "footer", "stripClasses": true },
          { "selector": ".user-cell", "tag": "span", "stripClasses": true, "removeAttributes": ["style"] },
          { "selector": ".user-name", "tag": "strong", "stripClasses": true },
          { "selector": ".user-email", "tag": "small", "stripClasses": true, "removeAttributes": ["style"] },
          { "selector": ".avatar", "tag": "figure", "keepAttributes": ["data-initials"] }
        ]
      },
      "list": {
        "selector": ".email-list",
        "targetTag": "aside",
        "stripClasses": true,
        "rules": [
          { "selector": ".top-bar", "tag": "header", "stripClasses": true },
          { "selector": ".email-item", "tag": "article", "stripClasses": true },
          { "selector": ".email-meta", "tag": "div", "stripClasses": true },
          { "selector": ".email-sender", "tag": "span", "stripClasses": true },
          { "selector": ".email-subject", "tag": "h4", "stripClasses": true },
          { "selector": ".email-preview", "tag": "p", "stripClasses": true },
          { "selector": ".email-time", "tag": "time", "stripClasses": true },
          { "selector": ".label", "tag": "mark", "stripClasses": true, "keepAttributes": ["data-label"] }
        ]
      }
    }
  },
