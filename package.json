{
  "name": "@howssatoshi/quantumcss",
  "version": "1.11.0",
  "description": "Advanced utility-first CSS framework with JIT generation and modern components",
  "main": "dist/quantum.min.css",
  "bin": {
    "quantumcss": "src/cli.js"
  },
  "files": [
    "dist",
    "src",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.js --minify",
    "build:dev": "node scripts/build.js",
    "watch": "node scripts/build.js --watch",
    "docs": "node scripts/build.js --docs",
    "generate": "node src/cli.js",
    "generate:watch": "node src/cli.js --watch",
    "harvest:icons": "node scripts/harvest-icons.js",
    "release": "node scripts/release.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/macroadster/quantumcss.git"
  },
  "bugs": {
    "url": "https://github.com/macroadster/quantumcss/issues"
  },
  "homepage": "https://github.com/macroadster/quantumcss#readme",
  "keywords": [
    "css",
    "utility-first",
    "framework",
    "responsive",
    "modern",
    "jit",
    "starlight"
  ],
  "author": "Eric Yang",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "autoprefixer": "^10.4.27",
    "chokidar": "^5.0.0",
    "cssnano": "^7.1.3",
    "glob": "^13.0.0",
    "parse5": "^8.0.0",
    "postcss": "^8.5.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "eslint": "^9.39.2",
    "stylelint": "^17.1.1",
    "stylelint-config-standard": "^40.0.0"
  }
}
